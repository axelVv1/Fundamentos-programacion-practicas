/*
Inicio
Leer num
Si num % 2 == 0 Entonces
    Escribir "Par"
Si no
    Escribir "Impar"
Fin Si
Fin
*/

#include <stdio.h>

int main() {
    int num;

    printf("Ingrese un numero:\n");
    scanf("%d", &num);

    if (num % 2 == 0) {
        printf("Es par\n");
    } else {
        printf("Es impar\n");
    }

    return 0;
}
