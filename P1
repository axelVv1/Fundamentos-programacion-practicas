#include <stdio.h>

int main() {

    char nombre[100];
    int edad;
    char carrera[100];
    int semestre;

    printf("Ingrese el nombre completo:\n");
    fgets(nombre, 100, stdin);

    printf("Ingrese la edad:\n");
    scanf("%d", &edad);
    getchar();

    printf("Ingrese la carrera:\n");
    fgets(carrera, 100, stdin);

    printf("Ingrese el semestre:\n");
    scanf("%d", &semestre);

    printf("\n----- DATOS DEL ESTUDIANTE -----\n");
    printf("Nombre: %s", nombre);
    printf("Edad: %d\n", edad);
    printf("Carrera: %s", carrera);
    printf("Semestre: %d\n", semestre);

    return 0;
}
